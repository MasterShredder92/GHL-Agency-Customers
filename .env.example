# ZiroWork GHL Agency — Environment Variables Template
# Copy to .env and fill in YOUR actual values
# .env is in .gitignore and should NEVER be committed

# ===== GHL (GoHighLevel) — AGENCY ACCOUNT =====
GHL_API_KEY=
GHL_AGENCY_ID=

# ===== GHL — ADKINS SUB-ACCOUNT =====
GHL_ADKINS_API_KEY=
GHL_ADKINS_LOCATION_ID=

# ===== SQUARE API (Adkins) =====
SQUARE_APP_ID=
SQUARE_ACCESS_TOKEN=
SQUARE_APP_SECRET=
SQUARE_API_VERSION=2026-05-20

# ===== SQUARE LOCATIONS (Adkins Music Lessons) =====
SQUARE_LOCATION_OMAHA=
SQUARE_LOCATION_BELLEVUE=
SQUARE_LOCATION_GRETNA=
SQUARE_LOCATION_ELKHORN=

# ===== SQUARE WEBHOOKS (Adkins) =====
SQUARE_WEBHOOK_SUBSCRIPTION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_URL=

# ===== CLIENT CONTACT INFO (Adkins) =====
ADKINS_EMAIL=
ADKINS_PHONE=
ADKINS_WEBSITE=

# ===== ENVIRONMENT =====
NODE_ENV=development
DEBUG=false
